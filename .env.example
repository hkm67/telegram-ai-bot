TELEGRAM_BOT_TOKEN=your_bot_token_here
BOT_USERNAME=tj

# Primary LLM backend. Use local Ollama first; Gemini is used as fallback.
LLM_BACKEND=ollama
OLLAMA_MODEL=gemma4:26b

# Used as fallback if local Ollama fails
# Get a free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_FALLBACK_MODEL=gemini-2.0-flash
LLM_MODEL=gemini-2.0-flash

# Local Ollama server. Put your private LAN/Tailscale URL in .env.
OLLAMA_HOST=http://your-ollama-host:11434
# Recommended Ollama model: gemma4:26b
OLLAMA_NUM_CTX=65536
OLLAMA_THINK=false

# Comma-separated Telegram user IDs allowed to use /model command
# Find your ID by messaging @userinfobot on Telegram
ADMIN_USER_IDS=123456789
